{
  // Minimal high-value ruleset (company standard): blank lines around fences (MD031),
  // language on fences (MD040). Local pre-commit only; not a CI gate.
  "config": {
    "default": false,
    "MD031": true,
    "MD040": true
  },
  "ignores": [
    "node_modules/**",
    ".dart_tool/**",
    "build/**"
  ]
}
